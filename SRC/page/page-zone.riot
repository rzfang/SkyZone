      }

      >div:nth-child(2) {
        text-align: center;
      }

      >div:last-child {
        position: absolute;
        right: 5px;
        bottom: 5px;
      }
    }
  </style>
  <script>
    export default {
      components: { datetime, iconButton, toTopButton },

      state: {
        messages: [],
      },

      async onBeforeMount () {
        const response = await fetch('/service/message?Lmt=5');

        const {
          Extend: messages,
          Index: error = -1,
          Message: message = '',
        } = await response.json();

        if (error !== 0) {
          return alert(message);
        }

        this.update({ messages });
      },

      async loadMore () {
        const { messages } = this.state;

        const offset = messages.length;

        const response = await fetch(`/service/message?Lmt=5&Ofst=${offset}`);

        const {
          Extend: newMessages = [],
          Index: error = -1,
          Message: message = '',
        } = await response.json();

        if (error != 0) {
          return alert(message);
        }

        this.update({ messages: [ ...messages, ...newMessages ], isNoMore: newMessages.length < 5 });
      },
    };
  </script>
</messages>

<page-zone>
  <header id='Head'>
    <div>
      <button class='Btn0' title='關於' onclick={openAboutFrame}>關於</button>
      <button class='Btn0' title='網誌' onclick={openBlogsFrame}>網誌</button>
      <button class='Btn0' title='留言板' onclick={openMessagesFrame}>留言板</button>
      <a href='/'><button title='回入口'>回入口</button></a>
    </div>
  </header>
  <main id='Main'>
    <art-corner />
    <good-words />
    <desk-frame
      each={frame in state.frames}
      key={frame.title}
      frametitle={frame.title}
      height={frame.height}
      left={frame.left}
      top={frame.top}
      width={frame.width}
    >
      <div is={frame.slot} id={frame.id || frame.title} />
    </desk-frame>
  </main>
  <footer id='Tail'>
    ©2011-2025 RZ Fang
  </footer>
  <store name='FRAMES' listener={onFramesStoreUpdate} />
  <style>
    :host {
      display: flex;
      flex-direction: column;
      width: 100vw;
      height: 100vh;

      >header {
        flex: 0 0 auto;
        text-align: center;

        >div {
          display: inline-flex;
          gap: 10px;
        }
      }

      >main {
        flex: 1 1 auto;
      }

      >footer {
        flex: 0 0 auto;
        text-align: center;
      }
    }
  </style>
  <script>
    export default {
      components: { about, artCorner, blog, blogs, deskFrame, goodWords, messages, store },

      state: {
        frames: [],
      },

      onMounted () {
        // To Do: riot-4-fun Store.riot should handle initial value.
        this.StoreSet('FRAMES', () => ({
          frames: [],
          rootElement: this.$('main'),
        }));
      },

      onFramesStoreUpdate (store) {
        this.update({ frames: store.frames });
      },

      openAboutFrame () {
        this.StoreSet(
          'FRAMES',
          store => {
            const { frames, rootElement } = store;

            const index = frames.findIndex(one => one.title === '關於');

            if (index < 0) {
              frames.push({
                height: 480,
                left: Math.floor((rootElement.offsetWidth - 640) / 2) + (frames.length * 5),
                slot: 'about',
                title: '關於',
                top: Math.floor((rootElement.offsetHeight - 480) / 2) + (frames.length * 5),
                width: 640,
              });
            } else {
              const [ aboutFrame ] = frames.splice(index, 1);

              frames.push(aboutFrame);
            }

            return store;
          }
        );
      },

      openBlogsFrame () {
        this.StoreSet(
          'FRAMES',
          store => {
            const { frames, rootElement } = store;

            const index = frames.findIndex(one => one.title === '網誌');

            if (index < 0) {
              frames.push({
                height: rootElement.offsetHeight,
                left: 0,
                slot: 'blogs',
                title: '網誌',
                top: rootElement.offsetTop,
                width: 320,
              });
            } else {
              const [ blogsFrame ] = frames.splice(index, 1);

              frames.push(blogsFrame);
            }

            return store;
          }
        );
      },

      openMessagesFrame () {
        this.StoreSet(
          'FRAMES',
          store => {
            const { frames, rootElement } = store;

            const index = frames.findIndex(one => one.title === '留言板');

            if (index < 0) {
              frames.push({
                height: rootElement.offsetHeight,
                slot: 'messages',
                title: '留言板',
                left: 0,
                top: rootElement.offsetTop,
                width: 320,
              });
            } else {
              const [ blogsFrame ] = frames.splice(index, 1);

              frames.push(blogsFrame);
            }

            return store;
          }
        );
      },
    };
  </script>
</page-zone>
