  <div><button onclick={loadMore}>載入更多</button></div>
  <div>
    <to-top-button target={root} />
  </div>
  <style>
    :host {
      height: 100%;
      overflow: auto;

      datetime {
        margin-left: 5px;
      }

      >ul>li {
        margin-bottom: 20px;

        >pre {
          margin: 5px 0;
          max-height: 100px;
          white-space: pre;
          overflow: hidden;
          text-overflow: ellipsis;
        }

        >div:last-child {
          >datetime {
            vertical-align: middle;
          }
